#==============================================================
# HISTORIQUE DES COMMANDES - LABORATOIRE SÉCURITÉ MOBILE
# Application : InsecureBankv2.apk
# Analyste : Chaira Hajar
# Date : 22/03/2026
#==============================================================

# -------------------------------------------------------------
# TASK 1 — Setup & Preparation
# -------------------------------------------------------------
# Création des répertoires de travail
mkdir 00-scope
mkdir 01-bevigil
mkdir 02-yaazhini
mkdir 03-triage
mkdir 04-report

# Initialisation du log de traçabilité
"Log Init..." | Out-File -FilePath "commands.log" -Encoding utf8

# -------------------------------------------------------------
# TASK 2 — Intégrité de l'Application et Reconnaissance OSINT
# -------------------------------------------------------------
# Calcul de l'empreinte pour la "Chain Of Custody"
Get-FileHash -Path "00-scope\InsecureBankv2.apk" -Algorithm SHA256

# Migration des exports BeVigil téléchargés vers le répertoire
Move-Item -Path "$env:USERPROFILE\Downloads\*.csv" -Destination "01-bevigil\" -ErrorAction SilentlyContinue

# Extraction de la reconnaissance Backend (SAST statique BeVigil)
"Exportation JSON/CSV de BeVigil enregistrée manuellement." | Out-File -FilePath "commands.log" -Encoding utf8 -Append

# -------------------------------------------------------------
# TASK 5 — Analyse Dynamique et Décompilation Yaazhini
# -------------------------------------------------------------
# Lancement de l'outil logiciel en mode Headless (Exemple de syntaxe CLI)
& "C:\Program Files\Yaazhini\yaazhini.exe" -apk "00-scope\InsecureBankv2.apk" -output "02-yaazhini"

# Enregistrement des découvertes 
"Génération des rapports HTML et notes Yaazhini (yaazhini_notes.md)" | Out-File -FilePath "commands.log" -Encoding utf8 -Append

# -------------------------------------------------------------
# TASK 7 — Normalisation et Dédoublonnage (Triage)
# -------------------------------------------------------------
# Créer le fichier triage.csv avec l'en-tête (Dédoublonnage)
"ID,Source,Élément,Preuve,Confiance,Sévérité,Impact,Recommandation,Référence OWASP,Statut" | Out-File -FilePath "03-triage\triage.csv" -Encoding utf8

# Ajouter quelques exemples pour guider le remplissage
@"
FIND-001,BeVigil,API Key exposée,bevigil_export.json:section assets,Forte,High,Accès non autorisé aux services backend,Utiliser un mécanisme sécurisé de stockage des clés,MASVS-STORAGE-1,Confirmé
FIND-002,Yaazhini,Communication en clair,AndroidManifest.xml:usesCleartextTraffic,Forte,High,Interception des données (AitM),Désactiver le trafic en clair,MASVS-NETWORK-1,Confirmé
"@ | Out-File -FilePath "03-triage\triage.csv" -Encoding utf8 -Append

# -------------------------------------------------------------
# TASK 8 — Corrélation OWASP
# -------------------------------------------------------------
# Mapping des faiblesses vers le référentiel MASVS
@"
# Cartographie OWASP MASVS

| ID Constat | Catégorie OWASP | Règle MASVS | Justification |
|------------|-----------------|-------------|---------------|
| FIND-001   | MASVS-STORAGE   | MSTG-STORAGE-1 | Le constat indique qu'une clé API est stockée en clair, ce qui viole la règle de stockage sécurisé. |
| FIND-002   | MASVS-NETWORK   | MSTG-NETWORK-1 | L'application autorise le trafic HTTP non chiffré, exposant les jetons d'authentification. |
"@ | Out-File -FilePath "03-triage\owasp_mapping.md" -Encoding utf8

# -------------------------------------------------------------
# TASK 9 — Rédaction Rapport Final
# -------------------------------------------------------------
# Création et initialisation du rapport de sécurité exécutif (Squelette type)
@"
# Rapport d'Analyse de Sécurité Mobile - InsecureBankv2
## A. Informations générales
- Date: 2026-03-22
- Analyste: Chaira Hajar
- Cible: InsecureBankv2.apk
"@ | Out-File -FilePath "04-report\rapport_final.md" -Encoding utf8

# -------------------------------------------------------------
# TASK 10 — Nettoyage et Clôture
# -------------------------------------------------------------
# Créer le fichier checklist de livraison
@"
# Checklist de fin d'analyse

## Périmètre et traçabilité
- [x] Scope clairement défini et respecté
- [x] Informations de traçabilité complètes
- [x] Hash de l'APK documenté (B18AF2A0E44D763...)

## Collecte et analyse
- [x] Exports BeVigil sauvegardés
- [x] Rapport Yaazhini sauvegardé
- [x] Notes d'analyse complètes

## Triage et reporting
- [x] Triage.csv rempli avec tous les constats
- [x] Mapping OWASP réalisé pour au moins 5 constats
- [x] Rapport final complet et structuré

## Sécurité et conformité
- [x] Aucun secret exposé dans les fichiers (Balise [MASQUÉ] utilisée)
- [x] Aucune donnée personnelle exposée
- [x] Aucune technique d'exploitation documentée

Je soussigné(e) Chaira Hajar certifie avoir réalisé cette analyse dans le respect du périmètre autorisé et des règles éthiques définies.

Date: 22/03/2026
Signature: Chaira Hajar
"@ | Out-File -FilePath "checklist_fin.md" -Encoding utf8

# Enregistrer la commande finale dans le log (Clôture formelle de la mission)
"Created checklist_fin.md" | Out-File -FilePath "commands.log" -Encoding utf8 -Append
